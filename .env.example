PORT=3001
NODE_ENV=development
ALLOWED_ORIGINS=http://127.0.0.1:3001,http://localhost:3001

# Keep all keys on the server. The mini program must never contain these values.
HERMES_MOCK=true
HERMES_API_MODE=local-cli
HERMES_API_URL=https://your-hermes-api.example.com/v1/agent
HERMES_API_KEY=replace_with_server_side_key_only
HERMES_AGENT_ID=star-growth-partner-agent
HERMES_MODEL=learning-coach
HERMES_PROJECT_SOUL_PATH=server/prompts/star-growth-soul.md

# Local Hermes CLI mode. Keep toolsets narrow for the child-facing surface.
HERMES_LOCAL_CLI_COMMAND=hermes
HERMES_LOCAL_CLI_TOOLSETS=clarify
HERMES_LOCAL_CLI_MODEL=
HERMES_LOCAL_CLI_PROVIDER=
HERMES_LOCAL_CLI_TIMEOUT_MS=60000

# Empty by default: do not enable terminal, file system, arbitrary browsing, or other high-risk tools.
HERMES_ALLOWED_TOOLS=

DEFAULT_DAILY_LIMIT_MINUTES=25
