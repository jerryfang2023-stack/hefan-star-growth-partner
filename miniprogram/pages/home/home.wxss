.reward-overlay {
  position: fixed;
  inset: 0;
  z-index: 20;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  pointer-events: none;
}

.reward-panel {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 18rpx;
  padding: 42rpx 48rpx 38rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.72);
  border-radius: 8rpx;
  background: linear-gradient(155deg, rgba(246, 243, 255, 0.96), rgba(226, 244, 255, 0.94));
  box-shadow: 0 36rpx 90rpx rgba(36, 33, 58, 0.28);
  animation: reward-pop 760ms cubic-bezier(.2, 1.35, .24, 1) both;
}

.reward-medal {
  width: 220rpx;
  height: 220rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 12rpx solid #ffe08a;
  border-radius: 999rpx;
  color: #31275f;
  background: radial-gradient(circle at 36% 28%, #fff9c7, #ffd25f 50%, #f0a928 100%);
  box-shadow: inset 0 0 0 10rpx rgba(255, 255, 255, 0.44), 0 22rpx 44rpx rgba(138, 90, 31, 0.28);
  font-size: 46rpx;
  font-weight: 900;
  line-height: 1.05;
  text-align: center;
}

.reward-points {
  color: #5b5ce2;
  font-size: 68rpx;
  font-weight: 900;
  line-height: 1;
}

.reward-note {
  color: #6f6a8b;
  font-size: 25rpx;
  font-weight: 700;
}

@keyframes reward-pop {
  0% {
    opacity: 0;
    transform: translateY(18rpx) scale(0.72) rotate(-4deg);
  }
  52% {
    opacity: 1;
    transform: translateY(0) scale(1.06) rotate(2deg);
  }
  100% {
    opacity: 1;
    transform: translateY(0) scale(1) rotate(0);
  }
}

.home-hero {
  position: relative;
  overflow: hidden;
  padding: 24rpx;
  border: 1rpx solid rgba(118, 112, 231, 0.24);
  border-radius: 8rpx;
  background: linear-gradient(145deg, rgba(245, 244, 255, 0.92), rgba(232, 244, 255, 0.88)), #ffffff;
  animation: fade-in 360ms ease both;
}

.hero-kicker {
  color: #5b5ce2;
  font-size: 40rpx;
  font-weight: 900;
  line-height: 1.18;
  letter-spacing: 0;
}

.hero-subtitle {
  margin-top: 10rpx;
  color: #6f6a8b;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.45;
}

.quest-map {
  width: 100%;
  height: 280rpx;
  margin-top: 24rpx;
  display: block;
  border: 1rpx solid rgba(203, 198, 255, 0.78);
  border-radius: 8rpx;
  box-shadow: 0 24rpx 42rpx rgba(56, 103, 214, 0.16);
  animation: map-float 4.8s ease-in-out infinite;
}

@keyframes map-float {
  0%,
  100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-8rpx);
  }
}

.mission-dock {
  margin-top: 22rpx;
  display: grid;
  grid-template-columns: 132rpx minmax(0, 1fr);
  gap: 18rpx;
  align-items: center;
  padding: 18rpx;
  border-radius: 8rpx;
  color: #ffffff;
  background: linear-gradient(135deg, rgba(44, 41, 105, 0.97), rgba(72, 80, 212, 0.9)), #29265f;
  box-shadow: 0 22rpx 40rpx rgba(36, 33, 58, 0.16);
}

.mission-art {
  width: 132rpx;
  height: 120rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.24);
  border-radius: 8rpx;
}

.mission-label {
  color: rgba(255, 255, 255, 0.68);
  font-size: 22rpx;
  font-weight: 800;
}

.mission-title {
  margin-top: 8rpx;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.25;
}

.mission-desc {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.74);
  font-size: 23rpx;
  line-height: 1.45;
}

.start-button {
  margin-top: 18rpx;
}

.quest-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.quest-card {
  width: 100%;
  min-height: 0;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin: 0;
  padding: 18rpx;
  border: 1rpx solid #dcd8fb;
  border-radius: 8rpx;
  background: #ffffff;
  text-align: left;
  box-shadow: 0 14rpx 32rpx rgba(55, 49, 108, 0.07);
  line-height: normal;
  animation: card-rise 420ms ease both;
}

.quest-card:nth-child(2) {
  animation-delay: 45ms;
}

.quest-card:nth-child(3) {
  animation-delay: 90ms;
}

.quest-card:nth-child(4) {
  animation-delay: 135ms;
}

.quest-card:nth-child(5) {
  animation-delay: 180ms;
}

.quest-card:nth-child(6) {
  animation-delay: 225ms;
}

@keyframes card-rise {
  from {
    opacity: 0;
    transform: translateY(18rpx) scale(0.98);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

.quest-card.active {
  border-color: #5b5ce2;
  box-shadow: 0 22rpx 44rpx rgba(91, 92, 226, 0.2);
}

.quest-card.feature {
  grid-column: 1 / -1;
  min-height: 318rpx;
  display: grid;
  grid-template-columns: 260rpx minmax(0, 1fr);
  align-items: center;
  background: linear-gradient(135deg, #ffffff, #f0f7ff);
}

.quest-card.split {
  grid-column: 1 / -1;
  display: grid;
  grid-template-columns: minmax(0, 1fr) 220rpx;
  align-items: center;
  background: linear-gradient(135deg, #f8f6ff, #ffffff);
}

.quest-card.scroll {
  min-height: 222rpx;
  color: #34295f;
  background:
    linear-gradient(135deg, rgba(255, 249, 232, 0.98), rgba(245, 236, 255, 0.95)),
    #fffaf0;
  border-color: #ead6a8;
}

.quest-card.note {
  min-height: 222rpx;
  color: #28234e;
  background:
    linear-gradient(180deg, rgba(236, 235, 255, 0.92), rgba(255, 255, 255, 0.98)),
    #ffffff;
}

.quest-card.mini {
  min-height: 186rpx;
}

.quest-card.calm {
  background: linear-gradient(135deg, #ffffff, #f3fbff);
  border-color: #cce8f2;
}

.quest-card-art {
  width: 100%;
  height: 172rpx;
  border-radius: 8rpx;
  background: #ecebff;
}

.quest-card.feature .quest-card-art {
  width: 260rpx;
  height: 236rpx;
}

.quest-card.split .quest-card-art {
  width: 220rpx;
  height: 178rpx;
  order: 2;
}

.quest-card-mark {
  width: 74rpx;
  height: 74rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #5b5ce2, #2aa8c6);
  font-size: 28rpx;
  font-weight: 900;
  box-shadow: 0 12rpx 24rpx rgba(91, 92, 226, 0.18);
}

.scroll .quest-card-mark {
  color: #6b4c13;
  background: linear-gradient(135deg, #ffe6a3, #d49b35);
}

.note .quest-card-mark {
  background: linear-gradient(135deg, #5b5ce2, #8b72ff);
}

.calm .quest-card-mark {
  background: linear-gradient(135deg, #2aa8c6, #75d6e8);
}

.quest-card-body {
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 9rpx;
}

.quest-card-title {
  color: #24213a;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1.2;
}

.feature .quest-card-title {
  font-size: 34rpx;
}

.quest-card-desc {
  color: #6f6a8b;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.35;
}

.quest-card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.quest-card-tag {
  padding: 7rpx 12rpx;
  border-radius: 999rpx;
  color: #4f4c75;
  background: #f0eefc;
  font-size: 20rpx;
  font-weight: 900;
  line-height: 1;
}

.home-playground {
  margin-top: 22rpx;
  padding: 22rpx;
  border: 1rpx solid #dcd8fb;
  border-radius: 8rpx;
  background: #ffffff;
}

.play-kicker {
  color: #5b5ce2;
  font-size: 22rpx;
  font-weight: 800;
}

.play-title {
  margin-top: 8rpx;
  color: #24213a;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.3;
}

.play-question {
  margin-top: 14rpx;
  color: #2d294f;
  font-size: 26rpx;
  line-height: 1.55;
}

.level-row {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 16rpx;
  color: #6f6a8b;
  font-size: 23rpx;
  font-weight: 700;
}

.quest-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
}

.quest-chip {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  color: #4f4c75;
  background: #f0eefc;
  font-size: 21rpx;
  font-weight: 800;
}

.quest-chip.hot {
  color: #ffffff;
  background: linear-gradient(135deg, #5b5ce2, #2aa8c6);
}

.progress-track {
  height: 12rpx;
  margin-top: 12rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #ece9fb;
}

.progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #5b5ce2, #2aa8c6);
}

.mini-steps {
  display: grid;
  gap: 12rpx;
  margin-top: 16rpx;
}

.mini-step {
  padding: 14rpx 16rpx;
  border: 1rpx solid #ece9fb;
  border-radius: 8rpx;
  color: #35315f;
  background: #faf9ff;
  font-size: 24rpx;
  line-height: 1.45;
}

.answer-line {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  gap: 12rpx;
  margin-top: 18rpx;
  align-items: center;
}

.play-input {
  min-height: 60rpx;
  padding: 0 18rpx;
  border: 1rpx solid #d6d2ef;
  border-radius: 8rpx;
  color: #24213a;
  background: #fafaff;
  font-size: 25rpx;
  box-sizing: border-box;
}

.play-answer {
  margin-top: 16rpx;
  color: #1c7a5a;
  font-size: 25rpx;
  font-weight: 700;
}

.play-feedback {
  margin-top: 16rpx;
  color: #6f6a8b;
  font-size: 24rpx;
  line-height: 1.45;
}

.play-feedback.good {
  color: #1c7a5a;
  font-weight: 700;
}

.play-feedback.try {
  color: #815116;
}

.play-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.compact-button {
  min-height: 60rpx;
  margin: 0;
  padding: 0 18rpx;
  font-size: 24rpx;
  line-height: 60rpx;
}

.ghost-button {
  color: #5b5ce2;
  background: #ecebff;
}

.module-card {
  padding: 22rpx;
  border: 1rpx solid #e1ddfb;
  border-radius: 8rpx;
  background: #ffffff;
}

.primary-module {
  padding: 26rpx;
  border-color: #cbc6ff;
  background: linear-gradient(180deg, rgba(236, 235, 255, 0.9), rgba(255, 255, 255, 0.98)), #ffffff;
}

.support-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.support-module {
  min-height: 214rpx;
}

.rest-module {
  border-color: #ead8bf;
  background: #fffaf4;
}

.module-head {
  display: grid;
  grid-template-columns: 60rpx 1fr;
  gap: 16rpx;
  align-items: center;
}

.module-mark {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  color: #ffffff;
  background: #5b5ce2;
  font-size: 25rpx;
  font-weight: 900;
}

.support-module:nth-child(1) .module-mark {
  background: #2aa8c6;
}

.support-module:nth-child(2) .module-mark {
  background: #6d5bd0;
}

.rest-module .module-mark {
  background: #b36a2e;
}

.module-title {
  color: #24213a;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.2;
}

.module-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.mission-option {
  min-height: 56rpx;
  margin: 0;
  padding: 0 18rpx;
  border: 1rpx solid #dcd8fb;
  border-radius: 8rpx;
  color: #3c3671;
  background: #fafaff;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 56rpx;
}

.primary-module .mission-option {
  min-height: 60rpx;
  line-height: 60rpx;
}

.rest-module .mission-option {
  min-height: 52rpx;
  color: #765018;
  border-color: #ecd9bd;
  background: #fffdf9;
  font-size: 23rpx;
  line-height: 52rpx;
}

.mission-option.active {
  color: #ffffff;
  border-color: #5b5ce2;
  background: #5b5ce2;
}
