.plan-dashboard {
  display: grid;
  grid-template-columns: repeat(5, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 24rpx;
}

.plan-stat {
  padding: 18rpx 8rpx;
  border: 1rpx solid #dedbf4;
  border-radius: 8rpx;
  background: #ffffff;
  text-align: center;
}

.stat-number {
  display: block;
  color: #5b5ce2;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1.05;
}

.stat-label {
  display: block;
  margin-top: 8rpx;
  color: #6f6a8b;
  font-size: 20rpx;
  font-weight: 800;
}

.plan-form {
  display: grid;
  gap: 14rpx;
  margin-top: 22rpx;
  padding: 22rpx;
  border: 1rpx solid #dedbf4;
  border-radius: 8rpx;
  background: linear-gradient(135deg, rgba(236, 235, 255, 0.88), rgba(255, 255, 255, 0.98));
}

.form-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
}

.date-row {
  grid-template-columns: 1fr 1fr 0.78fr;
}

.plan-input,
.plan-picker {
  min-height: 72rpx;
  padding: 0 20rpx;
  border: 1rpx solid #dcd8fb;
  border-radius: 8rpx;
  color: #24213a;
  background: #ffffff;
  font-size: 25rpx;
  line-height: 72rpx;
}

.date-picker {
  padding: 0 14rpx;
  font-size: 22rpx;
}

.plan-card {
  margin-bottom: 18rpx;
}

.plan-section-title {
  margin: 0 0 16rpx;
  color: #24213a;
  font-size: 30rpx;
  font-weight: 900;
}

.plan-card.done {
  border-color: #bde6ce;
  background: linear-gradient(135deg, #f5fff8, #ffffff);
}

.plan-card.missed {
  border-color: #efd3bb;
  background: linear-gradient(135deg, #fff8ef, #ffffff);
}

.plan-topline {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 10rpx;
}

.plan-type {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  color: #4735a9;
  background: #efedff;
  font-size: 22rpx;
  font-weight: 900;
}

.plan-state {
  color: #6f6a8b;
  font-size: 22rpx;
  font-weight: 800;
}

.plan-title {
  margin-bottom: 8rpx;
  color: #24213a;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1.25;
}

.plan-schedule {
  margin-bottom: 8rpx;
  color: #5b5ce2;
  font-size: 23rpx;
  font-weight: 850;
  line-height: 1.4;
}

.step {
  margin-top: 12rpx;
  color: #2d294f;
  font-size: 26rpx;
  line-height: 1.45;
}

.plan-reason {
  margin-top: 14rpx;
  padding: 14rpx;
  border-radius: 8rpx;
  color: #735126;
  background: #fff5e8;
  font-size: 24rpx;
  line-height: 1.45;
}

.plan-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.plan-actions button {
  min-height: 54rpx;
  margin: 0;
  padding: 0 18rpx;
  border-radius: 8rpx;
  color: #4a35a3;
  background: #efedff;
  font-size: 23rpx;
  font-weight: 800;
  line-height: 54rpx;
}

.plan-actions .danger-button {
  color: #9a2f4d;
  background: #fff0f4;
}
