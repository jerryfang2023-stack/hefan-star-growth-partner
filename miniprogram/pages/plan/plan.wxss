.plan-card {
  margin-bottom: 18rpx;
}

.plan-topline {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.plan-day {
  color: #5b5ce2;
  font-size: 26rpx;
  font-weight: 700;
}

.plan-minutes {
  color: #6f6a8b;
  font-size: 24rpx;
}

.plan-title {
  margin-bottom: 8rpx;
  font-size: 32rpx;
  font-weight: 700;
}

.step {
  margin-top: 12rpx;
  color: #2d294f;
  font-size: 26rpx;
  line-height: 1.45;
}
